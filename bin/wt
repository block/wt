#!/usr/bin/env bash
#
# wt — Standalone wrapper for non-interactive shells
# ====================================================
#
# This script provides the `wt` command in environments where wt.sh
# cannot be sourced (non-interactive shells, scripts, Claude Code, etc.).
#
# In interactive shells where wt.sh IS sourced, the wt() shell function
# takes priority over this script (functions resolve before PATH executables).
#
# Limitation: `wt cd` requires wt.sh sourced in an interactive shell
# (a subprocess cannot change the parent's working directory).
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"

# Run a sibling wt-* command
_run() {
  local cmd="$1"; shift
  if [[ -x "$SCRIPT_DIR/wt-$cmd" ]]; then
    exec "$SCRIPT_DIR/wt-$cmd" "$@"
  else
    echo "wt: command script not found: wt-$cmd" >&2
    exit 127
  fi
}

# Show help by sourcing the help library (needs wt-common for config vars)
_show_help() {
  # Temporarily allow unset variables — wt_show_help references WT_* config
  # variables that may be unset if no repository context is configured yet
  set +u
  if [[ -f "$LIB_DIR/wt-common" ]]; then
    . "$LIB_DIR/wt-common"
  elif [[ -f "$HOME/.wt/lib/wt-common" ]]; then
    . "$HOME/.wt/lib/wt-common"
  fi
  if [[ -f "$LIB_DIR/wt-help" ]]; then
    . "$LIB_DIR/wt-help"
  elif [[ -f "$HOME/.wt/lib/wt-help" ]]; then
    . "$HOME/.wt/lib/wt-help"
  fi
  if command -v wt_show_help &>/dev/null; then
    wt_show_help
  else
    set -u
    echo "wt: help library not found" >&2
    exit 1
  fi
  set -u
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  add)             _run add "$@" ;;
  adopt)           _run adopt "$@" ;;
  switch)          _run switch "$@" ;;
  remove)          _run remove "$@" ;;
  list)            _run list "$@" ;;
  context)         _run context "$@" ;;
  metadata-export) _run metadata-export "$@" ;;
  metadata-import) _run metadata-import "$@" ;;
  # Legacy aliases
  ijwb-export)     _run metadata-export "$@" ;;
  ijwb-import)     _run metadata-import "$@" ;;
  cd)
    echo "wt cd: requires an interactive shell with wt.sh sourced." >&2
    echo "  In scripts, use: cd \"\$(~/.wt/bin/wt-cd [worktree])\"" >&2
    exit 1
    ;;
  help|--help|-h)
    _show_help
    ;;
  *)
    echo "wt: unknown command '$cmd'" >&2
    echo "Run 'wt help' for usage information." >&2
    exit 1
    ;;
esac
